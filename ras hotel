<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Diredawa Ras Hotel</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root {
  --gold: #C9A84C;
  --gold-light: #E8C97A;
  --gold-dark: #9B7A28;
  --forest: #1A2E22;
  --forest-mid: #243D2E;
  --forest-light: #2E5040;
  --cream: #F8F4EC;
  --cream-dark: #EDE7D9;
  --text-dark: #1A1A1A;
  --text-mid: #4A4A4A;
  --text-light: #7A7A7A;
  --white: #FFFFFF;
  --shadow: 0 8px 40px rgba(0,0,0,0.15);
  --shadow-sm: 0 4px 20px rgba(0,0,0,0.1);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Jost',sans-serif;background:var(--cream);color:var(--text-dark);overflow-x:hidden;}
h1,h2,h3,h4{font-family:'Cormorant Garamond',serif;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(26,46,34,0.97);backdrop-filter:blur(10px);padding:0 5%;display:flex;align-items:center;justify-content:space-between;height:72px;border-bottom:1px solid rgba(201,168,76,0.2);}
.logo{display:flex;align-items:center;gap:12px;text-decoration:none;}
.logo-icon{width:44px;height:44px;background:var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-weight:700;font-size:16px;color:var(--forest);}
.logo-text{color:var(--white);}
.logo-text h4{font-size:14px;font-weight:600;letter-spacing:2px;color:var(--gold);font-family:'Jost',sans-serif;}
.logo-text p{font-size:10px;letter-spacing:3px;color:rgba(255,255,255,0.6);font-weight:300;}
.nav-links{display:flex;align-items:center;gap:32px;list-style:none;}
.nav-links a{color:rgba(255,255,255,0.85);text-decoration:none;font-size:12px;letter-spacing:2px;font-weight:500;transition:color 0.3s;}
.nav-links a:hover{color:var(--gold);}
.nav-right{display:flex;align-items:center;gap:16px;}
.phone-link{color:var(--gold);font-size:13px;letter-spacing:1px;text-decoration:none;font-weight:500;}
.btn-nav{background:var(--gold);color:var(--forest);padding:10px 24px;font-size:11px;letter-spacing:2px;font-weight:600;border:none;cursor:pointer;font-family:'Jost',sans-serif;transition:all 0.3s;}
.btn-nav:hover{background:var(--gold-light);}

/* LANG SELECTOR */
.lang-select{background:transparent;border:1px solid rgba(201,168,76,0.4);color:var(--gold);padding:6px 10px;font-size:11px;cursor:pointer;font-family:'Jost',sans-serif;letter-spacing:1px;}

/* HERO */
.hero{height:100vh;position:relative;display:flex;align-items:center;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0d1f15 0%,#1a2e22 40%,#243d2e 70%,#1a2e22 100%);}
.hero-pattern{position:absolute;inset:0;opacity:0.04;background-image:repeating-linear-gradient(45deg,#C9A84C 0,#C9A84C 1px,transparent 0,transparent 50%);background-size:20px 20px;}
.hero-building{position:absolute;right:0;top:0;bottom:0;width:60%;background:linear-gradient(to left,rgba(26,46,34,0) 0%,rgba(26,46,34,0.6) 100%);overflow:hidden;}
.hero-building-img{width:100%;height:100%;object-fit:cover;opacity:0.55;filter:sepia(20%) saturate(1.3);}
.hero-content{position:relative;z-index:2;padding:0 5%;max-width:620px;animation:fadeInUp 1.2s ease;}
.hero-eyebrow{font-size:11px;letter-spacing:4px;color:var(--gold);font-weight:500;margin-bottom:16px;text-transform:uppercase;}
.hero-title{font-size:clamp(52px,7vw,88px);font-weight:300;color:var(--white);line-height:1;margin-bottom:8px;}
.hero-title span{color:var(--gold);font-style:italic;}
.hero-subtitle{font-size:16px;color:rgba(255,255,255,0.7);font-weight:300;letter-spacing:0.5px;margin-bottom:40px;line-height:1.7;}
.hero-actions{display:flex;gap:16px;flex-wrap:wrap;}
.btn-gold{background:var(--gold);color:var(--forest);padding:16px 36px;font-size:12px;letter-spacing:3px;font-weight:600;border:none;cursor:pointer;font-family:'Jost',sans-serif;transition:all 0.3s;text-transform:uppercase;text-decoration:none;display:inline-block;}
.btn-gold:hover{background:var(--gold-light);transform:translateY(-2px);}
.btn-outline{background:transparent;color:var(--white);padding:16px 36px;font-size:12px;letter-spacing:3px;font-weight:500;border:1px solid rgba(255,255,255,0.4);cursor:pointer;font-family:'Jost',sans-serif;transition:all 0.3s;text-transform:uppercase;display:flex;align-items:center;gap:10px;}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);}
.play-icon{width:20px;height:20px;background:var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;}
.play-icon::after{content:'';border-left:7px solid var(--forest);border-top:4px solid transparent;border-bottom:4px solid transparent;margin-left:2px;}

/* BOOKING WIDGET */
.booking-widget{background:var(--white);box-shadow:var(--shadow);padding:28px 36px;display:flex;align-items:center;gap:0;border-top:3px solid var(--gold);position:relative;z-index:10;margin:0 5%;transform:translateY(-40px);border-radius:0;}
.booking-field{flex:1;padding:0 28px;border-right:1px solid var(--cream-dark);}
.booking-field:last-of-type{border-right:none;}
.booking-field label{display:block;font-size:9px;letter-spacing:3px;color:var(--gold);font-weight:600;margin-bottom:8px;text-transform:uppercase;}
.booking-field select,.booking-field input{width:100%;border:none;font-size:14px;color:var(--text-dark);font-family:'Jost',sans-serif;background:transparent;outline:none;cursor:pointer;}
.booking-field-icon{display:flex;align-items:center;gap:10px;}
.field-icon{width:20px;height:20px;color:var(--gold);}
.btn-check{background:var(--forest);color:var(--white);padding:20px 36px;font-size:11px;letter-spacing:3px;font-weight:600;border:none;cursor:pointer;font-family:'Jost',sans-serif;white-space:nowrap;transition:all 0.3s;text-transform:uppercase;}
.btn-check:hover{background:var(--forest-light);}

/* FEATURES BAR */
.features-bar{background:var(--forest);padding:32px 5%;display:flex;justify-content:space-between;flex-wrap:wrap;gap:24px;}
.feature-item{display:flex;align-items:center;gap:16px;color:var(--white);}
.feature-icon{width:44px;height:44px;background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.feature-icon svg{width:20px;height:20px;stroke:var(--gold);fill:none;stroke-width:1.5;}
.feature-text h4{font-size:14px;font-weight:500;color:var(--white);font-family:'Jost',sans-serif;margin-bottom:3px;}
.feature-text p{font-size:12px;color:rgba(255,255,255,0.5);font-weight:300;}

/* SECTION STYLES */
section{padding:90px 5%;}
.section-eyebrow{font-size:10px;letter-spacing:4px;color:var(--gold);font-weight:600;text-transform:uppercase;text-align:center;margin-bottom:12px;}
.section-title{font-size:clamp(36px,5vw,56px);font-weight:300;text-align:center;color:var(--forest);margin-bottom:20px;line-height:1.1;}
.section-title em{font-style:italic;color:var(--gold-dark);}
.section-line{width:60px;height:2px;background:var(--gold);margin:0 auto 48px;}

/* ROOMS */
.rooms-section{background:var(--cream);}
.rooms-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;}
.room-card{background:var(--white);overflow:hidden;transition:transform 0.4s,box-shadow 0.4s;cursor:pointer;}
.room-card:hover{transform:translateY(-8px);box-shadow:var(--shadow);}
.room-img{height:240px;background:var(--forest-mid);position:relative;overflow:hidden;}
.room-img-inner{width:100%;height:100%;object-fit:cover;transition:transform 0.6s;}
.room-card:hover .room-img-inner{transform:scale(1.06);}
.room-badge{position:absolute;top:16px;left:16px;background:var(--gold);color:var(--forest);font-size:10px;letter-spacing:2px;padding:4px 12px;font-weight:600;}
.room-info{padding:24px;}
.room-name{font-size:22px;font-weight:400;color:var(--forest);margin-bottom:8px;}
.room-price{color:var(--gold);font-size:14px;font-weight:600;letter-spacing:1px;margin-bottom:16px;}
.room-price span{color:var(--text-light);font-size:12px;font-weight:400;}
.room-features{display:flex;gap:16px;margin-bottom:20px;}
.room-feature{font-size:11px;color:var(--text-light);display:flex;align-items:center;gap:5px;}
.room-feature svg{width:14px;height:14px;stroke:var(--gold);fill:none;stroke-width:2;}
.btn-room{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;background:var(--cream);color:var(--forest);font-size:11px;letter-spacing:2px;font-weight:600;font-family:'Jost',sans-serif;border:none;cursor:pointer;width:100%;transition:all 0.3s;}
.btn-room:hover{background:var(--forest);color:var(--gold);}
.btn-room svg{width:18px;height:18px;}

/* SERVICES */
.services-section{background:var(--forest);color:var(--white);}
.services-section .section-title{color:var(--white);}
.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}
.service-card{padding:32px 24px;border:1px solid rgba(201,168,76,0.15);transition:all 0.3s;}
.service-card:hover{background:rgba(201,168,76,0.08);border-color:rgba(201,168,76,0.4);}
.service-card-icon{width:52px;height:52px;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:20px;}
.service-card-icon svg{width:24px;height:24px;stroke:var(--gold);fill:none;stroke-width:1.5;}
.service-card h3{font-size:20px;font-weight:400;color:var(--gold);margin-bottom:10px;}
.service-card p{font-size:13px;color:rgba(255,255,255,0.55);line-height:1.7;font-weight:300;}

/* GALLERY */
.gallery-section{background:var(--cream);}
.gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:240px 240px;gap:16px;}
.gallery-item{overflow:hidden;background:var(--forest-mid);position:relative;}
.gallery-item.tall{grid-row:span 2;}
.gallery-item.wide{grid-column:span 2;}
.gallery-item-inner{width:100%;height:100%;background:var(--forest-mid);position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden;transition:transform 0.5s;}
.gallery-item:hover .gallery-item-inner{transform:scale(1.05);}
.gallery-label{position:absolute;bottom:0;left:0;right:0;padding:20px;background:linear-gradient(to top,rgba(26,46,34,0.85),transparent);color:var(--white);font-size:13px;letter-spacing:1px;font-weight:400;transform:translateY(100%);transition:transform 0.3s;}
.gallery-item:hover .gallery-label{transform:translateY(0);}
.gallery-placeholder{font-size:40px;opacity:0.15;color:var(--gold);}

/* OFFERS */
.offers-section{background:var(--forest-mid);color:var(--white);}
.offers-section .section-title{color:var(--white);}
.offers-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.offer-card{background:rgba(255,255,255,0.05);border:1px solid rgba(201,168,76,0.2);padding:32px;position:relative;overflow:hidden;transition:all 0.3s;}
.offer-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--gold);}
.offer-card:hover{background:rgba(201,168,76,0.08);}
.offer-discount{font-size:40px;font-weight:700;color:var(--gold);font-family:'Cormorant Garamond',serif;margin-bottom:8px;}
.offer-title{font-size:20px;font-weight:400;color:var(--white);margin-bottom:12px;}
.offer-desc{font-size:13px;color:rgba(255,255,255,0.55);line-height:1.7;margin-bottom:24px;}
.offer-cta{font-size:11px;letter-spacing:2px;color:var(--gold);font-weight:600;text-decoration:none;display:flex;align-items:center;gap:8px;border:none;background:none;cursor:pointer;font-family:'Jost',sans-serif;}
.offer-cta svg{width:16px;height:16px;stroke:var(--gold);fill:none;stroke-width:2;}

/* CONTACT */
.contact-section{background:var(--cream);}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;}
.contact-info h2{font-size:42px;font-weight:300;color:var(--forest);margin-bottom:20px;line-height:1.2;}
.contact-info h2 em{font-style:italic;color:var(--gold-dark);}
.contact-info p{font-size:15px;color:var(--text-mid);line-height:1.8;margin-bottom:32px;}
.contact-details{display:flex;flex-direction:column;gap:16px;}
.contact-detail{display:flex;align-items:flex-start;gap:14px;}
.contact-detail-icon{width:36px;height:36px;background:var(--forest);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;}
.contact-detail-icon svg{width:16px;height:16px;stroke:var(--gold);fill:none;stroke-width:2;}
.contact-detail h4{font-size:11px;letter-spacing:2px;color:var(--gold);font-weight:600;margin-bottom:4px;font-family:'Jost',sans-serif;}
.contact-detail p{font-size:14px;color:var(--text-mid);}

/* FORM */
.contact-form{background:var(--white);padding:40px;box-shadow:var(--shadow-sm);}
.form-group{margin-bottom:20px;}
.form-group label{display:block;font-size:10px;letter-spacing:2px;color:var(--gold);font-weight:600;margin-bottom:8px;text-transform:uppercase;}
.form-group input,.form-group textarea,.form-group select{width:100%;border:none;border-bottom:1px solid var(--cream-dark);padding:12px 0;font-size:14px;font-family:'Jost',sans-serif;color:var(--text-dark);background:transparent;outline:none;transition:border-color 0.3s;}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-bottom-color:var(--gold);}
.form-group textarea{resize:none;height:100px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:20px;}

/* FOOTER */
footer{background:var(--forest);color:var(--white);padding:60px 5% 0;}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;padding-bottom:48px;border-bottom:1px solid rgba(201,168,76,0.15);}
.footer-brand .logo-icon{width:50px;height:50px;font-size:18px;margin-bottom:16px;}
.footer-brand p{font-size:13px;color:rgba(255,255,255,0.5);line-height:1.8;font-weight:300;max-width:280px;margin-top:16px;}
.footer-col h4{font-size:11px;letter-spacing:3px;color:var(--gold);font-weight:600;margin-bottom:20px;font-family:'Jost',sans-serif;text-transform:uppercase;}
.footer-col ul{list-style:none;}
.footer-col ul li{margin-bottom:10px;}
.footer-col ul li a{color:rgba(255,255,255,0.55);text-decoration:none;font-size:13px;font-weight:300;transition:color 0.3s;}
.footer-col ul li a:hover{color:var(--gold);}
.footer-bottom{padding:24px 0;display:flex;justify-content:space-between;align-items:center;}
.footer-bottom p{font-size:12px;color:rgba(255,255,255,0.35);font-weight:300;}
.footer-credit{font-size:12px;color:rgba(255,255,255,0.35);text-align:right;}
.footer-credit .creator{color:rgba(255,255,255,0.5);}

/* MODAL OVERLAY */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(10,20,14,0.92);z-index:9999;align-items:center;justify-content:center;padding:20px;}
.modal-overlay.active{display:flex;}
.modal{background:var(--white);max-width:520px;width:100%;max-height:90vh;overflow-y:auto;position:relative;animation:slideUp 0.4s ease;}
.modal-header{background:var(--forest);padding:32px 36px;color:var(--white);}
.modal-header h2{font-size:28px;font-weight:300;color:var(--white);}
.modal-header p{font-size:13px;color:rgba(255,255,255,0.5);margin-top:6px;}
.modal-close{position:absolute;top:20px;right:20px;background:rgba(255,255,255,0.1);border:none;color:var(--white);width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;}
.modal-body{padding:36px;}
.modal-tabs{display:flex;gap:0;margin-bottom:28px;border-bottom:1px solid var(--cream-dark);}
.modal-tab{flex:1;padding:12px;text-align:center;font-size:12px;letter-spacing:2px;font-weight:600;cursor:pointer;border:none;background:none;font-family:'Jost',sans-serif;color:var(--text-light);border-bottom:2px solid transparent;transition:all 0.3s;}
.modal-tab.active{color:var(--forest);border-bottom-color:var(--gold);}
.tab-pane{display:none;}
.tab-pane.active{display:block;}
.form-input{width:100%;border:none;border:1px solid var(--cream-dark);padding:14px 16px;font-size:14px;font-family:'Jost',sans-serif;color:var(--text-dark);background:var(--cream);outline:none;margin-bottom:16px;transition:border-color 0.3s;}
.form-input:focus{border-color:var(--gold);}
.otp-hint{font-size:12px;color:var(--text-light);margin-bottom:16px;line-height:1.6;}
.otp-inputs{display:flex;gap:12px;margin-bottom:20px;justify-content:center;}
.otp-input{width:52px;height:56px;text-align:center;font-size:20px;font-weight:600;border:1px solid var(--cream-dark);background:var(--cream);font-family:'Jost',sans-serif;outline:none;transition:border-color 0.3s;}
.otp-input:focus{border-color:var(--gold);}
.auth-switch{font-size:13px;color:var(--text-light);text-align:center;margin-top:16px;}
.auth-switch a{color:var(--gold);cursor:pointer;text-decoration:none;}
.social-divider{display:flex;align-items:center;gap:12px;margin:20px 0;}
.social-divider::before,.social-divider::after{content:'';flex:1;height:1px;background:var(--cream-dark);}
.social-divider span{font-size:11px;color:var(--text-light);letter-spacing:1px;}

/* PAYMENT MODAL */
.payment-choices{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:24px;}
.payment-choice{border:1px solid var(--cream-dark);padding:24px;cursor:pointer;text-align:center;transition:all 0.3s;background:var(--cream);}
.payment-choice:hover{border-color:var(--gold);background:var(--white);}
.payment-choice h4{font-size:16px;font-weight:500;color:var(--forest);margin-bottom:8px;font-family:'Jost',sans-serif;}
.payment-choice p{font-size:12px;color:var(--text-light);}
.payment-logos{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:16px;}
.payment-logo{background:var(--white);border:1px solid var(--cream-dark);padding:5px 12px;font-size:10px;font-weight:700;letter-spacing:1px;border-radius:4px;color:var(--text-mid);}
.payment-logo.tele{color:#E62020;border-color:#E62020;}
.payment-logo.mpesa{color:#00B300;border-color:#00B300;}
.payment-logo.cbe{color:#00529B;border-color:#00529B;}
.payment-logo.dashen{color:#C8202E;border-color:#C8202E;}
.payment-logo.awash{color:#0A4C96;border-color:#0A4C96;}
.payment-logo.visa{color:#1A1F71;border-color:#1A1F71;}
.payment-logo.master{color:#EB001B;border-color:#EB001B;}
.payment-logo.amex{color:#007BC1;border-color:#007BC1;}
.payment-logo.paypal{color:#003087;border-color:#003087;}
.payment-logo.swift{color:#333;border-color:#ccc;}
.not-linked-msg{display:none;text-align:center;padding:32px;background:var(--cream);}
.not-linked-msg svg{width:48px;height:48px;stroke:var(--gold);fill:none;stroke-width:1;margin-bottom:16px;}
.not-linked-msg h3{font-size:22px;color:var(--forest);margin-bottom:8px;}
.not-linked-msg p{font-size:14px;color:var(--text-light);}

/* ANIMATIONS */
@keyframes fadeInUp{from{opacity:0;transform:translateY(40px);}to{opacity:1;transform:translateY(0);}}
@keyframes slideUp{from{opacity:0;transform:translateY(60px);}to{opacity:1;transform:translateY(0);}}

/* GALLERY COLORS */
.g1{background:linear-gradient(135deg,#1a3a2a,#2e5040);}
.g2{background:linear-gradient(135deg,#2e4030,#1a2e22);}
.g3{background:linear-gradient(135deg,#1a2e22,#3a5530);}
.g4{background:linear-gradient(135deg,#243d2e,#1a3025);}
.g5{background:linear-gradient(135deg,#1e3828,#2a4535);}

/* RESPONSIVE HELPERS */
@media(max-width:900px){
  .rooms-grid{grid-template-columns:1fr 1fr;}
  .services-grid{grid-template-columns:1fr 1fr;}
  .gallery-grid{grid-template-columns:1fr 1fr;grid-template-rows:auto;}
  .gallery-item.tall,.gallery-item.wide{grid-row:auto;grid-column:auto;}
  .offers-grid{grid-template-columns:1fr;}
  .contact-grid{grid-template-columns:1fr;}
  .footer-grid{grid-template-columns:1fr 1fr;}
  .nav-links{display:none;}
  .booking-widget{flex-direction:column;transform:translateY(0);margin:0;}
  .booking-field{border-right:none;border-bottom:1px solid var(--cream-dark);padding:16px 0;}
  .payment-choices{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="logo" href="#">
    <div class="logo-icon">DR</div>
    <div class="logo-text">
      <h4>DIREDAWA RAS HOTEL</h4>
      <p>COMFORT. HOSPITALITY. DIREDAWA.</p>
    </div>
  </a>
  <ul class="nav-links">
    <li><a href="#home">HOME</a></li>
    <li><a href="#rooms">ROOMS</a></li>
    <li><a href="#services">SERVICES</a></li>
