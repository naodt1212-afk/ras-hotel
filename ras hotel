<script>
function openModal(type){
  if(type==='auth') document.getElementById('authModal').classList.add('active');
  if(type==='payment'){
    document.getElementById('paymentModal').classList.add('active');
    resetPayment();
  }
}
function closeModal(type){
  if(type==='auth') document.getElementById('authModal').classList.remove('active');
  if(type==='payment') document.getElementById('paymentModal').classList.remove('active');
}
function switchTab(tab){
  document.querySelectorAll('.modal-tab').forEach((t,i)=>{t.classList.remove('active');});
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  const tabs=['login','register','otp'];
  const idx=tabs.indexOf(tab);
  document.querySelectorAll('.modal-tab')[idx].classList.add('active');
  document.getElementById('tab-'+tab).classList.add('active');
}
function showOTPInputs(){
  document.getElementById('otp-section').style.display='block';
  const inputs=document.querySelectorAll('.otp-input');
  inputs.forEach((inp,i)=>{
    inp.addEventListener('input',()=>{if(inp.value&&i<inputs.length-1)inputs[i+1].focus();});
  });
}
function showNotLinked(type){
  document.getElementById('paymentChoicesBody').style.display='none';
  document.getElementById('notLinkedMsg').style.display='block';
}
function resetPayment(){
  document.getElementById('paymentChoicesBody').style.display='block';
  document.getElementById('notLinkedMsg').style.display='none';
}
document.querySelectorAll('.modal-overlay').forEach(o=>{
  o.addEventListener('click',function(e){if(e.target===this){this.classList.remove('active');}});
});
const langMessages={
  am:'እንኳን ደህና መጡ — ዳይሬዳዋ ራስ ሆቴል',
  fr:'Bienvenue — Diredawa Ras Hotel',
  ar:'مرحباً بكم — فندق ديريداوا راس',
  zh:'欢迎光临 — 迪雷达瓦拉斯酒店',
  de:'Willkommen — Diredawa Ras Hotel',
  en:''
};
function changeLanguage(val){
  if(langMessages[val]){
    const banner=document.getElementById('langBanner');
    document.getElementById('langMsg').textContent=langMessages[val];
    banner.style.display='block';
    setTimeout(()=>banner.style.display='none',3000);
  }
}
// OTP auto-focus
document.addEventListener('DOMContentLoaded',()=>{
  document.querySelectorAll('.otp-input').forEach((inp,i,arr)=>{
    inp.addEventListener('keydown',(e)=>{
      if(e.key==='Backspace'&&!inp.value&&i>0)arr[i-1].focus();
    });
  });
});
</script>
